# Shared env file for frontend, backend, and Traefik

DOMAIN=bookazia.example.com
TRAEFIK_NETWORK=proxy
TRAEFIK_ENTRYPOINT=https
TRAEFIK_CERT_RESOLVER=letsencrypt

BACKEND_IMAGE=ghcr.io/owner/repo-backend:latest
FRONTEND_IMAGE=ghcr.io/owner/repo-frontend:latest
FRONTEND_API_URL=https://bookazia.example.com/api

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres-host:5432/bookazia_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SERVER_PORT=16741
SERVER_SERVLET_CONTEXT_PATH=/api
JWT_SECRET=change-me
APP_CORS_ALLOWED_ORIGINS=https://bookazia.example.com
