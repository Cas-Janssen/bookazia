FROM node:22-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .

ARG FRONTEND_API_URL=http://localhost:8080/api
RUN printf "export const environment = {\n  production: true,\n  apiUrl: '%s',\n  tokenIssuer: 'bookazia',\n};\n" "$FRONTEND_API_URL" > src/environments/environment.ts

RUN npm run build

FROM nginx:1.27-alpine
COPY --from=build /app/dist/bookazia/browser /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
